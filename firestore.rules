rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      // Anyone can read a user's basic profile (e.g., display name, photo URL) to render leaderboards/results.
      allow read: if true;
      
      // Only the authenticated user themselves can write/edit their own profile record.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default fallback rules
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
